<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.CiliInviteCodeMapper">

    <resultMap type="com.ruoyi.system.domain.CiliInviteCode" id="CiliInviteCodeResult">
        <result property="id" column="id"/>
        <result property="code" column="code"/>
        <result property="used" column="used"/>
        <result property="usedBy" column="used_by"/>
        <result property="usedAt" column="used_at"/>
        <result property="createdBy" column="create_by"/>
        <result property="createdAt" column="create_time"/>
        <result property="expiresAt" column="expires_at"/>
        <result property="maxUses" column="max_uses"/>
        <result property="useCount" column="use_count"/>
        <result property="status" column="status"/>
        <result property="batchNo" column="batch_no"/>
    </resultMap>

    <sql id="selectCiliInviteCodeVo">
        select id, code, used, used_by, used_at, create_by, create_time, expires_at, max_uses, use_count, status, batch_no
        from cili_invite_code
    </sql>

    <select id="selectCiliInviteCodeList" parameterType="com.ruoyi.system.domain.CiliInviteCode" resultMap="CiliInviteCodeResult">
        <include refid="selectCiliInviteCodeVo"/>
        <where>
            <if test="code != null and code != ''">
                AND code like concat('%', #{code}, '%')
            </if>
            <if test="used != null">
                AND used = #{used}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="batchNo != null and batchNo != ''">
                AND batch_no = #{batchNo}
            </if>
        </where>
        order by create_time desc
    </select>

    <select id="selectCiliInviteCodeById" parameterType="Long" resultMap="CiliInviteCodeResult">
        <include refid="selectCiliInviteCodeVo"/>
        where id = #{id}
    </select>

    <select id="selectCiliInviteCodeByCode" parameterType="String" resultMap="CiliInviteCodeResult">
        <include refid="selectCiliInviteCodeVo"/>
        where code = #{code}
    </select>

    <insert id="insertCiliInviteCode" parameterType="com.ruoyi.system.domain.CiliInviteCode" useGeneratedKeys="true" keyProperty="id">
        insert into cili_invite_code
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="code != null and code != ''">code,</if>
            <if test="used != null">used,</if>
            <if test="createdBy != null">create_by,</if>
            <if test="expiresAt != null">expires_at,</if>
            <if test="maxUses != null">max_uses,</if>
            <if test="useCount != null">use_count,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="batchNo != null">batch_no,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="code != null and code != ''">#{code},</if>
            <if test="used != null">#{used},</if>
            <if test="createdBy != null">#{createdBy},</if>
            <if test="expiresAt != null">#{expiresAt},</if>
            <if test="maxUses != null">#{maxUses},</if>
            <if test="useCount != null">#{useCount},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="batchNo != null">#{batchNo},</if>
        </trim>
    </insert>

    <update id="updateCiliInviteCode" parameterType="com.ruoyi.system.domain.CiliInviteCode">
        update cili_invite_code
        <trim prefix="SET" suffixOverrides=",">
            <if test="code != null and code != ''">code = #{code},</if>
            <if test="used != null">used = #{used},</if>
            <if test="usedBy != null">used_by = #{usedBy},</if>
            <if test="usedAt != null">used_at = #{usedAt},</if>
            <if test="expiresAt != null">expires_at = #{expiresAt},</if>
            <if test="maxUses != null">max_uses = #{maxUses},</if>
            <if test="useCount != null">use_count = #{useCount},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="batchNo != null">batch_no = #{batchNo},</if>
        </trim>
        where id = #{id}
    </update>

    <update id="useInviteCode">
        update cili_invite_code
        set used = used + 1,
            used_by = #{userId},
            used_at = NOW()
        where id = #{id} and used &lt; max_uses
    </update>

    <delete id="deleteCiliInviteCodeById" parameterType="Long">
        delete from cili_invite_code where id = #{id}
    </delete>

    <delete id="deleteCiliInviteCodeByIds" parameterType="Long">
        delete from cili_invite_code where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
