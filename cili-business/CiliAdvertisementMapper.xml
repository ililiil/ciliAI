<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.CiliAdvertisementMapper">

    <resultMap type="com.ruoyi.system.domain.CiliAdvertisement" id="CiliAdvertisementResult">
        <id property="id" column="id" />
        <result property="title" column="title" />
        <result property="position" column="position" />
        <result property="type" column="type" />
        <result property="imageUrl" column="image_url" />
        <result property="linkUrl" column="link_url" />
        <result property="code" column="code" />
        <result property="startTime" column="start_time" />
        <result property="endTime" column="end_time" />
        <result property="status" column="status" />
        <result property="sort" column="sort" />
        <result property="viewCount" column="view_count" />
        <result property="clickCount" column="click_count" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <sql id="selectCiliAdvertisementVo">
        select id, title, position, type, image_url, link_url, code, start_time, end_time, status, sort, view_count, click_count, create_time, update_time, remark from cili_advertisement
    </sql>

    <select id="selectCiliAdvertisementList" parameterType="com.ruoyi.system.domain.CiliAdvertisement" resultMap="CiliAdvertisementResult">
        <include refid="selectCiliAdvertisementVo"/>
        <where>
            <if test="title != null and title != ''">
                AND title like concat('%', #{title}, '%')
            </if>
            <if test="position != null and position != ''">
                AND position = #{position}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by sort asc, create_time desc
    </select>

    <select id="selectCiliAdvertisementById" parameterType="Long" resultMap="CiliAdvertisementResult">
        <include refid="selectCiliAdvertisementVo"/>
        where id = #{id}
    </select>

    <insert id="insertCiliAdvertisement" parameterType="com.ruoyi.system.domain.CiliAdvertisement">
        insert into cili_advertisement
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="title != null">title,</if>
            <if test="position != null">position,</if>
            <if test="type != null">type,</if>
            <if test="imageUrl != null">image_url,</if>
            <if test="linkUrl != null">link_url,</if>
            <if test="code != null">code,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="status != null">status,</if>
            <if test="sort != null">sort,</if>
            <if test="remark != null">remark,</if>
            create_time,
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="title != null">#{title},</if>
            <if test="position != null">#{position},</if>
            <if test="type != null">#{type},</if>
            <if test="imageUrl != null">#{imageUrl},</if>
            <if test="linkUrl != null">#{linkUrl},</if>
            <if test="code != null">#{code},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="status != null">#{status},</if>
            <if test="sort != null">#{sort},</if>
            <if test="remark != null">#{remark},</if>
            now(),
        </trim>
    </insert>

    <update id="updateCiliAdvertisement" parameterType="com.ruoyi.system.domain.CiliAdvertisement">
        update cili_advertisement
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null">title = #{title},</if>
            <if test="position != null">position = #{position},</if>
            <if test="type != null">type = #{type},</if>
            <if test="imageUrl != null">image_url = #{imageUrl},</if>
            <if test="linkUrl != null">link_url = #{linkUrl},</if>
            <if test="code != null">code = #{code},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="status != null">status = #{status},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteCiliAdvertisementByIds" parameterType="Long">
        delete from cili_advertisement where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteCiliAdvertisementById" parameterType="Long">
        delete from cili_advertisement where id = #{id}
    </delete>

</mapper>
