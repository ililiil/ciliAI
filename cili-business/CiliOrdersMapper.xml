<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.CiliOrdersMapper">

    <resultMap type="com.ruoyi.system.domain.CiliOrders" id="CiliOrdersResult">
        <id property="id" column="id" />
        <result property="orderNo" column="order_no" />
        <result property="userId" column="user_id" />
        <result property="productType" column="product_type" />
        <result property="productId" column="product_id" />
        <result property="computePower" column="compute_power" />
        <result property="amount" column="amount" />
        <result property="status" column="status" />
        <result property="payMethod" column="pay_method" />
        <result property="payTime" column="pay_time" />
        <result property="completeTime" column="complete_time" />
        <result property="refundTime" column="refund_time" />
        <result property="refundReason" column="refund_reason" />
        <result property="remark" column="remark" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectCiliOrdersVo">
        select id, order_no, user_id, product_type, product_id, compute_power, amount, status, pay_method, pay_time, complete_time, refund_time, refund_reason, remark, create_time, update_time from cili_orders
    </sql>

    <select id="selectCiliOrdersList" parameterType="com.ruoyi.system.domain.CiliOrders" resultMap="CiliOrdersResult">
        <include refid="selectCiliOrdersVo"/>
        <where>
            <if test="orderNo != null and orderNo != ''">
                AND order_no like concat('%', #{orderNo}, '%')
            </if>
            <if test="userId != null">
                AND user_id = #{userId}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by create_time desc
    </select>

    <select id="selectCiliOrdersById" parameterType="Long" resultMap="CiliOrdersResult">
        <include refid="selectCiliOrdersVo"/>
        where id = #{id}
    </select>

    <insert id="insertCiliOrders" parameterType="com.ruoyi.system.domain.CiliOrders">
        insert into cili_orders
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="orderNo != null and orderNo != ''">order_no,</if>
            <if test="userId != null">user_id,</if>
            <if test="productType != null and productType != ''">product_type,</if>
            <if test="productId != null">product_id,</if>
            <if test="computePower != null">compute_power,</if>
            <if test="amount != null">amount,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="payMethod != null">pay_method,</if>
            <if test="remark != null">remark,</if>
            create_time,
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="orderNo != null and orderNo != ''">#{orderNo},</if>
            <if test="userId != null">#{userId},</if>
            <if test="productType != null and productType != ''">#{productType},</if>
            <if test="productId != null">#{productId},</if>
            <if test="computePower != null">#{computePower},</if>
            <if test="amount != null">#{amount},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="payMethod != null">#{payMethod},</if>
            <if test="remark != null">#{remark},</if>
            now(),
        </trim>
    </insert>

    <update id="updateCiliOrders" parameterType="com.ruoyi.system.domain.CiliOrders">
        update cili_orders
        <trim prefix="SET" suffixOverrides=",">
            <if test="productType != null and productType != ''">product_type = #{productType},</if>
            <if test="computePower != null">compute_power = #{computePower},</if>
            <if test="amount != null">amount = #{amount},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="payMethod != null">pay_method = #{payMethod},</if>
            <if test="payTime != null">pay_time = #{payTime},</if>
            <if test="completeTime != null">complete_time = #{completeTime},</if>
            <if test="refundTime != null">refund_time = #{refundTime},</if>
            <if test="refundReason != null">refund_reason = #{refundReason},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteCiliOrdersByIds" parameterType="Long">
        delete from cili_orders where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteCiliOrdersById" parameterType="Long">
        delete from cili_orders where id = #{id}
    </delete>

</mapper>
