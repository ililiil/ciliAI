<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.CiliComputePowerMapper">

    <resultMap type="com.ruoyi.system.domain.CiliComputePower" id="CiliComputePowerResult">
        <result property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="balance" column="balance"/>
        <result property="totalRecharged" column="total_recharged"/>
        <result property="totalUsed" column="total_used"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <sql id="selectCiliComputePowerVo">
        select id, user_id, balance, total_recharged, total_used, updated_at, created_at
        from cili_compute_power
    </sql>

    <select id="selectCiliComputePowerList" parameterType="com.ruoyi.system.domain.CiliComputePower" resultMap="CiliComputePowerResult">
        <include refid="selectCiliComputePowerVo"/>
        <where>
            <if test="userId != null">
                AND user_id = #{userId}
            </if>
        </where>
        order by created_at desc
    </select>

    <select id="selectCiliComputePowerById" parameterType="Long" resultMap="CiliComputePowerResult">
        <include refid="selectCiliComputePowerVo"/>
        where id = #{id}
    </select>

    <select id="selectCiliComputePowerByUserId" parameterType="Long" resultMap="CiliComputePowerResult">
        <include refid="selectCiliComputePowerVo"/>
        where user_id = #{userId}
    </select>

    <insert id="insertCiliComputePower" parameterType="com.ruoyi.system.domain.CiliComputePower" useGeneratedKeys="true" keyProperty="id">
        insert into cili_compute_power
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="balance != null">balance,</if>
            <if test="totalRecharged != null">total_recharged,</if>
            <if test="totalUsed != null">total_used,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="balance != null">#{balance},</if>
            <if test="totalRecharged != null">#{totalRecharged},</if>
            <if test="totalUsed != null">#{totalUsed},</if>
        </trim>
    </insert>

    <update id="updateCiliComputePower" parameterType="com.ruoyi.system.domain.CiliComputePower">
        update cili_compute_power
        <trim prefix="SET" suffixOverrides=",">
            <if test="balance != null">balance = #{balance},</if>
            <if test="totalRecharged != null">total_recharged = #{totalRecharged},</if>
            <if test="totalUsed != null">total_used = #{totalUsed},</if>
            updated_at = NOW(),
        </trim>
        where user_id = #{userId}
    </update>

    <update id="rechargePower">
        update cili_compute_power
        set balance = balance + #{amount},
            total_recharged = total_recharged + #{amount},
            updated_at = NOW()
        where user_id = #{userId}
    </update>

    <update id="consumePower">
        update cili_compute_power
        set balance = balance - #{amount},
            total_used = total_used + #{amount},
            updated_at = NOW()
        where user_id = #{userId} and balance >= #{amount}
    </update>

    <delete id="deleteCiliComputePowerById" parameterType="Long">
        delete from cili_compute_power where id = #{id}
    </delete>

    <delete id="deleteCiliComputePowerByIds" parameterType="Long">
        delete from cili_compute_power where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
