# ============================================
# CiliAI Development Environment Configuration
# ============================================

# ============================================
# MySQL Database Configuration
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ciliai_dev
DB_USER=root
DB_PASSWORD=root_dev_password

# ============================================
# Flask Development Settings
# ============================================
FLASK_DEBUG=True
FLASK_ENV=development
FLASK_PORT=5001

# ============================================
# Volcano Engine API Credentials
# ============================================
VOLC_AK=your_dev_access_key_id
VOLC_SK=your_dev_secret_access_key

# ============================================
# Admin Backend URL
# ============================================
ADMIN_BASE_URL=http://localhost:5002
