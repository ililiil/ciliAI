# 火山引擎密钥（必填）
VOLC_AK=你的AccessKeyID
VOLC_SK=你的SecretAccessKey

# 数据库配置（可选，默认使用SQLite）
# 数据库类型：sqlite（默认）/ mysql / postgres
DB_TYPE=sqlite
# SQLite数据库文件路径（相对于项目根目录）
DB_PATH=fangtang.db
# MySQL/PostgreSQL配置（如果使用DB_TYPE=mysql或postgres）
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ciliai
DB_USER=root
DB_PASSWORD=your_password

# 管理后台地址（可选）
ADMIN_BASE_URL=http://localhost:5002

# Flask配置（可选）
FLASK_DEBUG=True
FLASK_PORT=5001
