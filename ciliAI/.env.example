# ============================================
# 火山引擎密钥配置（必填）
# ============================================
VOLC_AK=你的AccessKeyID
VOLC_SK=你的SecretAccessKey

# ============================================
# Dify 对话配置（必填）
# ============================================
DIFY_API_URL=https://whhongyi.com.cn/v1/chat-messages
DIFY_API_KEY=你的DifyApiKey

# ============================================
# MySQL 数据库配置（必填）
# ============================================
# 注意：项目已从 SQLite 迁移到 MySQL
# 请确保 MySQL 数据库已创建并配置正确

DB_HOST=localhost
DB_PORT=3306
DB_NAME=ciliai
DB_USER=root
DB_PASSWORD=your_password

# ============================================
# 管理后台配置（可选）
# ============================================
ADMIN_BASE_URL=http://localhost:5002

# ============================================
# Flask 配置（可选）
# ============================================
FLASK_DEBUG=True
FLASK_PORT=5001
