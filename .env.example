# ============================================
# 火山引擎密钥配置（必填）
# ============================================
VOLC_AK=你的AccessKeyID
VOLC_SK=你的SecretAccessKey

# ============================================
# Dify 对话配置（必填）
# ============================================
DIFY_API_URL=https://whhongyi.com.cn/v1/chat-messages
DIFY_API_KEY=你的DifyApiKey

# ============================================
# MySQL 数据库配置（必填）
# ============================================
# 注意：项目已从 SQLite 迁移到 MySQL
# 请确保 MySQL 数据库已创建并配置正确
# 重要：DB_USER 不能设置为 root，MySQL容器不允许用 MYSQL_USER 配置 root 用户

DB_TYPE=mysql
DB_HOST=ciliai-mysql
DB_PORT=3306
DB_NAME=ciliai
DB_USER=ciliai
DB_PASSWORD=ciliai_password
MYSQL_ROOT_PASSWORD=root_password

# ============================================
# 管理后台配置（可选）
# ============================================
ADMIN_BASE_URL=http://localhost:5002

# ============================================
# Flask 配置（可选）
# ============================================
FLASK_DEBUG=True
FLASK_PORT=5001
