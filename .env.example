# 火山引擎密钥（必填）
VOLC_AK=你的AccessKeyID
VOLC_SK=你的SecretAccessKey

# 数据库配置
# SQLite（默认）- 适用于开发和小型部署
DB_TYPE=sqlite
DB_PATH=fangtang.db

# MySQL（适用于生产环境）
# 取消下面注释并配置即可使用MySQL
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=ciliai
# DB_USER=root
# DB_PASSWORD=your_mysql_password

# PostgreSQL（适用于生产环境）
# 取消下面注释并配置即可使用PostgreSQL
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=ciliai
# DB_USER=postgres
# DB_PASSWORD=your_postgres_password

# 管理后台地址（可选）
ADMIN_BASE_URL=http://localhost:5002

# Flask配置（可选）
FLASK_DEBUG=True
FLASK_PORT=5001
