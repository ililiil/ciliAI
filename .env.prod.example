# ============================================
# CiliAI Docker Environment Configuration
# Production Environment Template
# ============================================

# ============================================
# MySQL Database Configuration
# ============================================
MYSQL_ROOT_PASSWORD=your_secure_root_password
MYSQL_DATABASE=ciliai
MYSQL_USER=ciliai_user
MYSQL_PASSWORD=your_secure_db_password
MYSQL_PORT=3306

# ============================================
# Application Ports
# ============================================
BACKEND_PORT=5001
FRONTEND_PORT=3003
ADMIN_PORT=3002

# ============================================
# Volcano Engine API Credentials
# ============================================
VOLC_AK=your_volc_access_key_id
VOLC_SK=your_volc_secret_access_key

# ============================================
# Flask Application Settings
# ============================================
FLASK_DEBUG=False
FLASK_ENV=production

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log

# ============================================
# Security Settings
# ============================================
SECRET_KEY=your_random_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here

# ============================================
# Optional: Redis Configuration
# ============================================
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password

# ============================================
# Optional: Nginx Configuration
# ============================================
# NGINX_MAX_BODY_SIZE=50m
# NGINX_WORKER_PROCESSES=auto
